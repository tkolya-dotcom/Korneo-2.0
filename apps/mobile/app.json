{
  "expo": {
    "name": "Korneo",
    "slug": "korneo-mobile",
    "version": "1.0.0",
    "scheme": "korneo",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f172a",
    "splash": {
      "backgroundColor": "#0f172a",
      "resizeMode": "contain"
    },
    "plugins": [
      "expo-router"
    ],
    "android": {
      "package": "com.tkolya.korneo",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.tkolya.korneo",
      "supportsTablet": true
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}